# =============================================================================
# Next.js 환경 변수 설정
# 이 파일을 복사하여 .env.local로 사용하세요:
#   cp .env.example .env.local
# =============================================================================

# --- API URL ---
# 클라이언트(브라우저)에서 접근하는 외부 API URL (Cloudflare 경유 등)
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# 서버(SSR)에서 Docker 내부 네트워크로 직접 호출하는 URL
INTERNAL_API_URL=http://cl_embed_laravel:8000/api

# --- Reverb (WebSocket) ---
NEXT_PUBLIC_REVERB_APP_KEY=
NEXT_PUBLIC_REVERB_HOST=

# --- E2E 테스트 ---
# Playwright E2E 테스트 실행 시 사용하는 인증 토큰
# E2E_TOKEN=your-test-token-here
