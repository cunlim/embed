{
  "openapi": "3.0.0",
  "info": {
    "title": "CL Embed Frontend API",
    "version": "1.0.0",
    "description": "Next.js 프론트엔드에서 호출하는 API 엔드포인트 명세. 실제 API는 Laravel 백엔드에서 처리됩니다."
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "API 서버 (환경변수 APP_URL로 설정)"
    }
  ],
  "paths": {
    "/api/recommend": {
      "post": {
        "tags": ["Recommend"],
        "summary": "카테고리 추천",
        "description": "검색어를 분석하여 적합한 카테고리를 추천합니다.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text", "target_language"],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "분석할 검색어",
                    "example": "여름 원피스"
                  },
                  "target_language": {
                    "type": "string",
                    "enum": ["ko", "zh", "en"],
                    "description": "추천 대상 언어"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "추천 결과",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "recommendations": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "category_code": { "type": "string" },
                          "category_name": { "type": "string" },
                          "similarity_score": { "type": "number" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
