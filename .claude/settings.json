{
  "permissions": {
    "deny": [
      "Read(/docker/db/**)",
      "Edit(/docker/db/**)",
      "Write(/docker/db/**)",
      "Bash(* /docker/db/**)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/run-all-checks.sh",
            "timeout": 360,
            "statusMessage": "테스트 및 린트 검사 중..."
          }
        ]
      }
    ]
  }
}
