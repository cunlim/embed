FROM node:24.15.0-trixie-slim

# 시스템 의존성 설치 (apt-get)
# - openssl, libssl-dev: 추후 Prisma 같은 ORM으로 PostgreSQL 연결 시 필수
# - postgresql-client: 컨테이너 내부에서 DB 핑(ping) 테스트 등 디버깅 목적
# - curl: 내부 헬스체크 및 Laravel API 통신 테스트 용도
# - procps: ps/pgrep/pkill 등 프로세스 관리 유틸리티
RUN apt-get update && apt-get install -y \
    curl \
    openssl \
    libssl-dev \
    postgresql-client \
    procps \
    && rm -rf /var/lib/apt/lists/*

# root 권한이 더 이상 필요하지 않으므로 node 사용자로 전환
USER node

WORKDIR /app

# 의존성 파일 먼저 복사 (레이어 캐싱 활용)
COPY package*.json ./

# npm 설정 (캐시 사용 및 무결성 확인)
# RUN npm init -y
# RUN npm ci --only=production --ignore-scripts
RUN npm ci

# 소스 코드 전체 복사 (불필요 파일은 .dockerignore로 제외)
COPY . ./

# 환경변수 정의 (예: development or production 구분)
# ENV NODE_ENV=development
ENV PORT=3000

EXPOSE 3000

# node 사용자로 .next 캐시 디렉토리 생성
RUN mkdir -p .next

# 개발/운영 모드 감지: .next/production 파일 존재 여부로 판단
# - .next/production 있음 → npm start (운영 모드, CI/CD 배포 시 생성)
# - .next/production 없음 → npm run dev (개발 모드)
# Next.js 16은 next dev도 BUILD_ID를 생성하므로 BUILD_ID로 판단 불가
CMD ["sh", "-c", "if [ -f .next/production ]; then exec npm start; else exec npm run dev; fi"]