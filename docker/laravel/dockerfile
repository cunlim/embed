FROM php:8.5.5-fpm-trixie


# Composer 설치 (멀티 스테이지 빌드 패턴 적용 - 매우 안전하고 빠름)
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer
#  PHP 확장 모듈 설치. 마법의 스크립트(install-php-extensions) 다운로드
COPY --from=mlocati/php-extension-installer /usr/bin/install-php-extensions /usr/local/bin/


# 필수 OS 유틸리티 패키지 설치 (PHP 확장용 라이브러리는 여기서 뺍니다)
RUN apt-get update && apt-get install -y \
procps curl tree nano vim cron wget acl supervisor \
# apt 캐시를 삭제하여 도커 이미지 용량 최적화
&& rm -rf /var/lib/apt/lists/*

RUN install-php-extensions intl mbstring zip bcmath gd imagick xdebug pdo_mysql pdo_pgsql redis pcntl

# 전용 사용자 생성 (uid/gid 1000 — 호스트 cunlim 사용자와 일치)
# -m: 홈 디렉토리 /home/appuser 자동 생성 + 소유권 설정 → chown 불필요
# supervisord와 모든 데몬이 이 사용자로 실행됨
RUN groupadd -g 1000 appgroup && useradd -u 1000 -g appgroup -m -d /home/appuser -s /bin/bash appuser

USER appuser

# 홈 디렉토리 내에 필요한 디렉토리 생성 (모두 appuser 소유)
RUN mkdir -p /home/appuser/.config/psysh \
    && mkdir -p /home/appuser/log/supervisor \
    && mkdir -p /home/appuser/log/php

# 프로세스 관리자 supervisord 설정
COPY --chown=appuser:appgroup supervisord.conf /etc/supervisor/supervisord.conf

CMD ["supervisord", "-c", "/etc/supervisor/supervisord.conf"]

