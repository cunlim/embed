                    "429": {
                        "description": "요청 횟수 초과"
                    }
                }
            }
        },
        "/api/recommend": {
            "post": {
                "tags": [
                    "Recommend"
                ],
                "summary": "카테고리 추천",
                "description": "입력 텍스트를 분석하여 pgvector 코사인 유사도 기반으로 가장 적합한 상위 5개 카테고리를 추천합니다.",
                "operationId": "c0c2c2f06d5fd5be7082cb942cf348e4",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
